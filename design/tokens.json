{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$meta": {
    "name": "Zümm Design Tokens",
    "description": "Source de vérité machine-lisible des tokens Zümm (SIG apicole). Miroir de DESIGN.md — en cas de doute, DESIGN.md (FR) fait foi. Format inspiré du DTCG (Design Tokens Community Group) : chaque token porte $value et $type.",
    "version": "1.1.0",
    "reference": "https://getdesign.md",
    "source": "./DESIGN.md"
  },

  "color": {
    "brand": {
      "honey-300": { "$type": "color", "$value": "#EBC55B", "$description": "Miel clair — surbrillances, badges, fonds doux." },
      "honey-500": { "$type": "color", "$value": "#D9A521", "$description": "Primaire — Miel. Accent principal, CTA, éléments actifs." },
      "honey-600": { "$type": "color", "$value": "#B8860B", "$description": "Miel foncé — survol/appui du primaire." },
      "green-300": { "$type": "color", "$value": "#6FC46B", "$description": "Vert clair — indicateurs positifs discrets, texte vert en mode sombre." },
      "green-500": { "$type": "color", "$value": "#2E9E3F", "$description": "Secondaire — Vert ruche. Succès, croissance." },
      "green-600": { "$type": "color", "$value": "#1F7A2E", "$description": "Vert foncé — survol/appui, texte vert fin sur clair." },
      "slate-800": { "$type": "color", "$value": "#2C4A42", "$description": "Neutre de marque — Vert ardoise. Wordmark, titres." },
      "slate-900": { "$type": "color", "$value": "#1E3A34", "$description": "Vert profond — fonds sombres, en-têtes, mode sombre." }
    },
    "neutral": {
      "ink": { "$type": "color", "$value": "#1B2320", "$description": "Texte principal (jamais #000)." },
      "ink-muted": { "$type": "color", "$value": "#5B6B65", "$description": "Texte secondaire, légendes, métadonnées." },
      "line": { "$type": "color", "$value": "#DCE4E0", "$description": "Bordures, séparateurs, contours de champs." },
      "surface": { "$type": "color", "$value": "#F5F7F5", "$description": "Fond de section, cartes en retrait." },
      "bg": { "$type": "color", "$value": "#FCFDFC", "$description": "Fond de page (mode clair) — blanc cassé teinté vert, jamais #FFFFFF pur." }
    },
    "semantic": {
      "success": { "$type": "color", "$value": "#2E9E3F", "$description": "Ruche saine, tâche terminée." },
      "warning": { "$type": "color", "$value": "#D9A521", "$description": "Alerte modérée, seuil approché." },
      "danger": { "$type": "color", "$value": "#C0392B", "$description": "Essaimage, capteur hors-ligne, erreur critique." },
      "info": { "$type": "color", "$value": "#2C7A7B", "$description": "Information neutre, télémétrie brute." }
    },
    "dark": {
      "bg": { "$type": "color", "$value": "#1E3A34" },
      "surface": { "$type": "color", "$value": "#25423B" },
      "text": { "$type": "color", "$value": "#EAF1EE" },
      "text-muted": { "$type": "color", "$value": "#A9BDB6" },
      "line": { "$type": "color", "$value": "rgba(255,255,255,0.10)" }
    },
    "data-categorical": {
      "$description": "Palette de séries (multi-ruches). Colorblind-safe, validée par script (ΔE adjacent min 35.9 clair / 40.5 sombre). À assigner dans l'ordre, jamais en boucle. NE PAS confondre avec color.semantic (états).",
      "light": {
        "cat-1": { "$type": "color", "$value": "#D9A521", "$description": "Miel — série principale." },
        "cat-2": { "$type": "color", "$value": "#2A78D6", "$description": "Bleu." },
        "cat-3": { "$type": "color", "$value": "#2E9E3F", "$description": "Vert ruche." },
        "cat-4": { "$type": "color", "$value": "#E87BA4", "$description": "Rose." },
        "cat-5": { "$type": "color", "$value": "#EB6834", "$description": "Orange." },
        "cat-6": { "$type": "color", "$value": "#4A3AA7", "$description": "Violet." },
        "cat-7": { "$type": "color", "$value": "#1BAF7A", "$description": "Aqua." }
      },
      "dark": {
        "cat-1": { "$type": "color", "$value": "#B8860B" },
        "cat-2": { "$type": "color", "$value": "#3987E5" },
        "cat-3": { "$type": "color", "$value": "#008300" },
        "cat-4": { "$type": "color", "$value": "#D55181" },
        "cat-5": { "$type": "color", "$value": "#D95926" },
        "cat-6": { "$type": "color", "$value": "#9085E9" },
        "cat-7": { "$type": "color", "$value": "#199E70" }
      }
    },
    "gradient-signature": {
      "$type": "gradient",
      "$value": "linear-gradient(120deg, #D9A521 0%, #2E9E3F 100%)",
      "$description": "Surfaces d'emphase uniquement (héro, page de garde, emblème). Jamais derrière du texte courant."
    }
  },

  "typography": {
    "family": {
      "ui": { "$type": "fontFamily", "$value": ["Inter", "-apple-system", "Segoe UI", "Roboto", "sans-serif"] },
      "ui-arabic": { "$type": "fontFamily", "$value": ["Cairo", "Tajawal", "IBM Plex Sans Arabic", "sans-serif"] },
      "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "monospace"] }
    },
    "scale": {
      "display": { "size": "40px", "weight": 700, "lineHeight": 1.1 },
      "h1": { "size": "32px", "weight": 700, "lineHeight": 1.15 },
      "h2": { "size": "25px", "weight": 600, "lineHeight": 1.2 },
      "h3": { "size": "20px", "weight": 600, "lineHeight": 1.3 },
      "body": { "size": "16px", "weight": 400, "lineHeight": 1.5 },
      "small": { "size": "14px", "weight": 400, "lineHeight": 1.45 },
      "caption": { "size": "12px", "weight": 500, "lineHeight": 1.4 }
    },
    "maxLineLength": "70ch"
  },

  "spacing": {
    "$type": "dimension",
    "scale": ["4px", "8px", "12px", "16px", "24px", "32px", "48px", "64px"],
    "gridGutter": "24px",
    "cardPadding": "16px–24px",
    "maxWidth": { "dashboard": "1200px", "reading": "720px" }
  },

  "radius": {
    "sm": { "$type": "dimension", "$value": "6px" },
    "md": { "$type": "dimension", "$value": "12px" },
    "lg": { "$type": "dimension", "$value": "20px" },
    "pill": { "$type": "dimension", "$value": "999px" }
  },

  "shadow": {
    "1": { "$type": "shadow", "$value": "0 1px 2px rgba(28,74,66,0.08)" },
    "2": { "$type": "shadow", "$value": "0 4px 12px rgba(28,74,66,0.10)" },
    "3": { "$type": "shadow", "$value": "0 12px 32px rgba(28,74,66,0.14)" }
  },

  "motion": {
    "duration": {
      "fast": { "$type": "duration", "$value": "120ms", "$description": "Micro : hover, swap d'icône, focus." },
      "base": { "$type": "duration", "$value": "200ms", "$description": "Standard : fondu, petit slide, badge." },
      "slow": { "$type": "duration", "$value": "320ms", "$description": "Ample : tiroir, panneau, transition de vue." },
      "modal-open": { "$type": "duration", "$value": "250ms" },
      "modal-close": { "$type": "duration", "$value": "150ms" }
    },
    "easing": {
      "out": { "$type": "cubicBezier", "$value": [0.22, 1, 0.36, 1], "$description": "Entrées (= --modal-ease)." },
      "in": { "$type": "cubicBezier", "$value": [0.4, 0, 1, 1], "$description": "Sorties." },
      "inout": { "$type": "cubicBezier", "$value": [0.65, 0, 0.35, 1], "$description": "Morph / redimensionnement." }
    },
    "amplitude": {
      "shift": { "$type": "dimension", "$value": "12px" },
      "scale-in": { "$type": "number", "$value": 0.96 }
    }
  }
}
