@startuml diagramme_composant
' Diagramme de composants - Zümm
skinparam shadowing false
skinparam componentStyle uml2
skinparam component {
  BackgroundColor #F3F2EE
  BorderColor #B8860B
  ArrowColor #B8860B
}
skinparam database {
  BackgroundColor #F3F2EE
  BorderColor #B8860B
}
title Diagramme de composants - Zümm

component "Client React\n(PWA, TypeScript)" as Web
component "Controleurs REST\n(Spring MVC)" as Ctrl
component "Module metier\n(services Spring)" as Metier
component "Module i18n\n(ressources par locale)" as I18n
component "Module configuration\n(ConfigZumm.ini + profils)" as Config
component "Adaptateur d'identite\n(OpenID Connect)" as OAuthC
database "PostgreSQL\n(PostGIS, TimescaleDB)" as DB

interface "getZummHoneyActualQuantity" as IHoney
interface "JPA / jOOQ" as IJpa
interface "API REST (OpenAPI 3)" as IRest

Web ..> IRest : consomme
IRest - Ctrl
Ctrl ..> Metier : utilise
Ctrl ..> I18n : utilise
Ctrl ..> Config : utilise
Ctrl ..> OAuthC : utilise
Metier - IJpa
IJpa - DB
Ctrl - IHoney

OAuthC ..> [Keycloak] : TLS 1.3 / X.509

@enduml
