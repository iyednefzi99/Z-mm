# Gabarit d'environnement pour la stack locale (infra/docker-compose.yml).
# Copier en `.env` a la racine. Ne jamais versionner de valeur reelle.
#
# Tous les mots de passe sont declares obligatoires dans le compose : la stack
# refuse de demarrer sans eux, plutot que de retomber sur une valeur devinable.

# Base de donnees PostgreSQL.
DB_PASSWORD=changez-moi

# Administration Keycloak (console d'administration du fournisseur d'identite).
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=changez-moi

# Interface Grafana.
GRAFANA_PASSWORD=changez-moi

# Profil Spring actif : dev | prod
SPRING_PROFILES_ACTIVE=dev

# Image PostgreSQL. Defaut : image locale construite par
# infra/test-postgres.Dockerfile (PostGIS + TimescaleDB).
# Cible de production : timescale/timescaledb-ha:pg16-ts2.14
# POSTGRES_IMAGE=timescale/timescaledb-ha:pg16-ts2.14
