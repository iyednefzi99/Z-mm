{
  "realm": "zumm",
  "enabled": true,
  "displayName": "Zümm",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "internationalizationEnabled": true,
  "supportedLocales": [
    "fr",
    "en",
    "ar"
  ],
  "defaultLocale": "fr",
  "roles": {
    "realm": [
      {
        "name": "apiculteur",
        "description": "Gere ses propres ruchers et saisit ses visites"
      },
      {
        "name": "superviseur",
        "description": "Supervise les agents et valide les visites"
      },
      {
        "name": "responsable",
        "description": "Pilote une ou plusieurs fermes"
      },
      {
        "name": "admin",
        "description": "Administration technique et parametrage"
      }
    ]
  },
  "clients": [
    {
      "clientId": "zumm-frontend",
      "name": "Client PWA Zümm",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/*"
      },
      "redirectUris": [
        "http://localhost:5173/*",
        "https://localhost/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "https://localhost"
      ],
      "protocolMappers": [
        {
          "name": "audience-backend",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "zumm-backend",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "zumm-backend",
      "name": "API Zümm",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false
    }
  ],
  "users": [
    {
      "username": "apiculteur-test",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Utilisateur",
      "lastName": "De test",
      "email": "apiculteur-test@example.invalid",
      "credentials": [
        {
          "type": "password",
          "value": "changez-moi",
          "temporary": false
        }
      ],
      "realmRoles": [
        "apiculteur"
      ]
    }
  ]
}
