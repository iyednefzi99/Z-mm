{
  "title": "Zümm — socle technique",
  "uid": "zumm-socle",
  "tags": ["zumm", "sprint-00"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Disponibilité de l'API",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Hors ligne", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "En ligne", "color": "green" } } }
          ]
        }
      },
      "targets": [{ "expr": "up{job=\"zumm-backend\"}", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requêtes HTTP par seconde",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{job=\"zumm-backend\"}[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latence p95 (s)",
      "description": "Cible NFR : p95 < 500 ms (US-038).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"zumm-backend\"}[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Connexions JDBC actives",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=\"zumm-backend\"}",
          "legendFormat": "actives",
          "refId": "A"
        }
      ]
    }
  ]
}
