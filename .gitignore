# ===== Code applicatif =====
# Backend (Maven)
target/
# Le wrapper Maven est versionne volontairement : il rend le depot buildable
# sans installation prealable de Maven. La negation doit venir apres la regle
# `*.jar` plus haut dans ce fichier, sinon le jar reste ignore et `./mvnw`
# echoue sur un clone neuf.
!backend/.mvn/wrapper/maven-wrapper.jar

# Frontend (Node)
node_modules/
dist/
dist-ssr/
*.local
.vite/
*.tsbuildinfo

# Secrets et configuration locale : seuls les gabarits *.example.* sont versionnes.
.env
.env.*
!.env.example
config/ConfigZumm.ini

# ===== IDE / OS =====
.idea/
*.iml
.vscode/
Thumbs.db
Desktop.ini
.DS_Store

# ===== Remarques =====
# Les PNG des diagrammes (images/*.png) et le PDF final (cahier_des_charges.pdf)
# sont VOLONTAIREMENT versionnes : ils font partie du livrable et evitent
# d'exiger PlantUML/Graphviz/LaTeX pour consulter le dossier.

# Sauvegardes locales : jamais versionnees (donnees, volumineuses).
sauvegardes/

# Certificats TLS : jamais versionnes, meme auto-signes de developpement.
# Ils sont regeneres par infra/generer-certificat-dev.sh.
infra/nginx/ssl/

# Realm Keycloak de developpement (mot de passe faible, direct-grant) — jamais versionne
infra/keycloak/realm-zumm.dev.json
